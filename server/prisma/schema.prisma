generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id           String   @id @default(uuid())
  name         String
  email        String?  @unique
  passwordHash String?
  avatar       String?
  theme        String   @default("dark")
  language     String   @default("fr")
  createdAt    DateTime @default(now())
  lastAccessed DateTime @updatedAt
  settings     Json?    // Stores API keys, preferences, etc.
  aiGenerationsCount Int @default(0) // Track AI usage for rate limiting
  
  courses    Course[]
  folders    Folder[]
  items      Item[]
  flashcards FlashcardSet[]
  quizzes    Quiz[]
  quizAttempts QuizAttempt[]
  summaries  Summary[]
  studyPlans StudyPlan[]
  mindmaps   MindMap[]
  studySessions StudySession[]
  notifications Notification[]
  
  // FinanceTrack Relations
  banks             Bank[]
  budgets           Budget[]
  recurringTransactions RecurringTransaction[]
  savingsGoals      SavingsGoal[]
  autoRules         AutoCategorizeRule[]
  financeAlerts     FinanceAlert[]
}

// ... existing models ...

// FinanceTrack Models

// FinanceTrack Models removed (defined at end of file)

model StudySession {
  id              String   @id @default(uuid())
  profileId       String
  courseId        String?
  date            DateTime
  startTime       DateTime
  durationMinutes Int
  type            String
  notes           String?  @db.Text
  createdAt       DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course  Course? @relation(fields: [courseId], references: [id])
}

model Course {
  id          String   @id @default(uuid())
  profileId   String
  title       String
  description String?
  color       String
  icon        String?
  folderId    String?
  isFavorite  Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  folder  Folder? @relation(fields: [folderId], references: [id])
  items   Item[]
  studyPlans StudyPlan[]
  studySessions StudySession[]
  summaries Summary[]
  mindmaps  MindMap[]

  @@index([profileId])
  @@index([folderId])
}

model Folder {
  id        String   @id @default(uuid())
  profileId String
  name      String
  parentId  String?
  createdAt DateTime @default(now())
  
  profile  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  parent   Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children Folder[] @relation("FolderHierarchy")
  courses  Course[]

  @@index([profileId])
  @@index([parentId])
}

model Item {
  id               String   @id @default(uuid())
  profileId        String
  courseId         String
  type             String   // 'note' | 'exercise' | 'resource'
  title            String
  content          String?  @db.Text
  fileUrl          String?
  fileName         String?
  fileType         String?  // MIME type (e.g., 'application/pdf')
  fileSize         Int?
  thumbnailUrl     String?  // URL to the generated thumbnail
  storageKey       String?  // S3 key
  status           String?
  difficulty       String?
  tags             String[]
  extractedContent String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([courseId])
  @@index([type])
}

model FlashcardSet {
  id          String   @id @default(uuid())
  profileId   String
  courseId    String?
  itemId      String?
  name        String
  description String?
  count       Int      @default(0)
  mastered    Int      @default(0)
  createdAt   DateTime @default(now())
  
  profile    Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]

  @@index([profileId])
  @@index([courseId])
  @@index([itemId])
}

model Flashcard {
  id           String   @id @default(uuid())
  setId        String
  front        String   @db.Text
  back         String   @db.Text
  nextReview   DateTime
  interval     Int      @default(1)
  easeFactor   Float    @default(2.5)
  createdAt    DateTime @default(now())
  lastReviewed DateTime?
  
  set FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@index([setId])
  @@index([nextReview])
}

model Quiz {
  id            String   @id @default(uuid())
  profileId     String
  courseId      String?
  name          String
  difficulty    String
  questionCount Int
  bestScore     Int?
  createdAt     DateTime @default(now())
  
  profile   Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@index([profileId])
  @@index([courseId])
}

model QuizAttempt {
  id        String   @id @default(uuid())
  profileId String
  quizId    String
  score     Int
  correctAnswers Int
  totalQuestions Int
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  quiz    Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([quizId])
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String
  stem          String   @db.Text
  options       String[]
  correctAnswer Int
  explanation   String   @db.Text
  
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model Summary {
  id        String   @id @default(uuid())
  profileId String
  courseId  String?
  itemId    String
  itemType  String
  generatedItemId String? // ID of the standalone Item created for this summary
  content   String   @db.Text
  stats     Json?
  options   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course  Course? @relation(fields: [courseId], references: [id])

  @@index([profileId, courseId])
  @@index([itemId])
}

model StudyPlan {
  id           String      @id @default(uuid())
  profileId    String
  courseId     String
  title        String
  goal         String
  deadline     DateTime
  hoursPerWeek Int
  status       String      @default("active")
  createdAt    DateTime    @default(now())
  
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  weeks   StudyWeek[]
  tasks   StudyTask[]

  @@index([profileId])
  @@index([courseId])
}

model StudyWeek {
  id         String   @id @default(uuid())
  planId     String
  weekNumber Int
  startDate  DateTime
  endDate    DateTime
  topics     String[]
  status     String   @default("upcoming")
  
  plan  StudyPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  tasks StudyTask[]

  @@index([planId])
}

model StudyTask {
  id              String  @id @default(uuid())
  weekId          String
  planId          String
  dayNumber       Int
  description     String
  durationMinutes Int
  type            String
  isCompleted     Boolean @default(false)
  
  week StudyWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  plan StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([weekId])
  @@index([planId])
}

model MindMap {
  id          String   @id @default(uuid())
  profileId   String
  courseId    String?
  name        String
  description String?
  content     String   @db.Text // Mermaid syntax
  sources     Json     // { noteIds: [ids], fileNames: [names] }
  createdAt   DateTime @default(now())
  
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  course  Course? @relation(fields: [courseId], references: [id])
}

// FinanceTrack Models (Phase 1 Integration)

model Bank {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  name        String
  swiftBic    String?
  color       String   @default("#10b981")
  icon        String?
  metadata    Json?
  active      Boolean  @default(true)
  
  accounts    Account[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([profileId, name])
  @@index([profileId])
}

model Account {
  id          String   @id @default(uuid())
  bankId      String
  bank        Bank     @relation(fields: [bankId], references: [id], onDelete: Cascade)
  
  name        String
  type        AccountType @default(CHECKING)
  iban        String?
  accountNumber String?
  currency    String   @default("EUR")
  balance     Decimal? @db.Decimal(15, 2)
  balanceDate DateTime?
  lastTransactionDate DateTime?
  
  autoDetected Boolean @default(false)
  importMetadata Json?
  active      Boolean  @default(true)
  
  transactions Transaction[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([bankId, iban])
  @@index([bankId])
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT
  INVESTMENT
  LOAN
  OTHER
}

model Transaction {
  id          String   @id @default(uuid())
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  date        DateTime
  amount      Decimal  @db.Decimal(15, 2)
  description String
  beneficiaryIban String?
  
  classification TransactionClassification @default(UNKNOWN)
  classificationConfidence Float? @default(0.0)
  linkedAccountId String? // Pour virements internes
  category    String?
  
  fitId       String? // FITID unique du fichier OFX pour meilleure détection doublons
  importSource String?
  metadata    Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([accountId, fitId])
  @@unique([accountId, date, amount, description])
  @@index([accountId, date])
  @@index([classification])
  @@index([category])
}

enum TransactionClassification {
  EXTERNAL
  INTERNAL_INTRA_BANK
  INTERNAL_INTER_BANK
  UNKNOWN
}

model ImportLog {
  id          String   @id @default(uuid())
  profileId   String
  filename    String
  status      String   // "SUCCESS", "PARTIAL", "ERROR"
  
  totalRows   Int
  imported    Int
  duplicates  Int
  errors      Int
  
  createdAt   DateTime @default(now())
}

model TransactionCategory {
  id          String   @id @default(uuid())
  profileId   String?  // User-specific categories
  name        String   // "Alimentation", "Loyer", "Salaire"
  type        String   // "INCOME", "EXPENSE"
  icon        String?  // Emoji
  color       String?  // Tailwind color class
  keywords    String[] @default([]) // Keywords for auto-categorization
  parentId    String?  // Hiérarchie (Biomes)
  
  parent       TransactionCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     TransactionCategory[] @relation("CategoryHierarchy")
  budgets      Budget[]
  
  @@unique([name, type]) // Commented out to fix migration conflict with existing duplicates
}

model Budget {
  id          String   @id @default(uuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  
  categoryId  String
  category    TransactionCategory @relation(fields: [categoryId], references: [id])
  
  amount      Decimal  @db.Decimal(10, 2)    // Montant limite
  period      String   @default("MONTHLY") // "MONTHLY", "WEEKLY", "YEARLY"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([profileId, categoryId])
}

// FinanceTrack — Recurring Transactions

model RecurringTransaction {
  id              String   @id @default(uuid())
  profileId       String

  description     String
  averageAmount   Decimal  @db.Decimal(15, 2)
  estimatedDay    Int
  frequency       RecurringFrequency @default(MONTHLY)
  category        String?
  type            String   // "INCOME" | "EXPENSE"

  lastSeenDate    DateTime?
  nextExpectedDate DateTime?
  occurrenceCount Int      @default(0)
  confidenceScore Float    @default(0.0)
  isActive        Boolean  @default(true)
  isPaused        Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, description, frequency])
  @@index([profileId])
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// FinanceTrack — Savings Goals

model SavingsGoal {
  id              String   @id @default(uuid())
  profileId       String

  name            String
  targetAmount    Decimal  @db.Decimal(15, 2)
  currentAmount   Decimal  @db.Decimal(15, 2) @default(0)
  deadline        DateTime?
  monthlyTarget   Decimal? @db.Decimal(15, 2)

  icon            String?  @default("🎯")
  color           String?  @default("#10b981")

  status          SavingsGoalStatus @default(ACTIVE)
  completedAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

enum SavingsGoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

// FinanceTrack — Auto-Categorization Rules

model AutoCategorizeRule {
  id              String   @id @default(uuid())
  profileId       String

  name            String          // "Carrefour → Alimentation"
  priority        Int      @default(0) // Lower = higher priority
  conditions      Json            // Array of {field, operator, value, caseSensitive?}
  categoryName    String          // Target category name

  isActive        Boolean  @default(true)
  matchCount      Int      @default(0) // Total matches counter

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

// Notifications
model Notification {
  id              String   @id @default(uuid())
  profileId       String
  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  type            String   // "QUIZ_RESULT" | "BUDGET_WARNING" | "STUDY_REMINDER" | "SYSTEM"
  title           String
  message         String
  data            Json?    // Contextual data (e.g., { courseId, quizId, amount })
  
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([profileId, isRead])
}

// FinanceTrack — Finance Alerts

model FinanceAlert {
  id              String   @id @default(uuid())
  profileId       String

  type            AlertType
  severity        AlertSeverity
  title           String
  message         String
  data            Json?

  isRead          Boolean  @default(false)
  isDismissed     Boolean  @default(false)

  createdAt       DateTime @default(now())

  profile         Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isRead])
}

enum AlertType {
  BUDGET_EXCEEDED
  BUDGET_WARNING
  LOW_BALANCE
  UNUSUAL_TRANSACTION
  RECURRING_MISSING
  GOAL_COMPLETED
  GOAL_AT_RISK
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
  CELEBRATION
}

